# Git attributes for consistent behavior across platforms

# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp
*.c text diff=c
*.py text diff=python
*.sh text eol=lf
*.bat text eol=crlf

# Documentation
*.md text
*.txt text
README text
LICENSE text

# CMake
CMakeLists.txt text
*.cmake text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.wav binary
*.mp3 binary
*.flac binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Compiled files (should not be in repo, but just in case)
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.app binary





